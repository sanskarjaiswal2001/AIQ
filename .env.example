# AIQ Configuration
# Copy this file to .env and edit before running `docker compose up`

# Admin API key — set this on first deploy to enable admin API access
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty for MVP (no auth required)
AIQ_ADMIN_KEY=

# Port for the mothership server (default 8000)
AIQ_PORT=8000
